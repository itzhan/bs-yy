<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.ProductDao">

    <resultMap type="com.entity.ProductEntity" id="productMap">
        <result property="id" column="id"/>
        <result property="productname" column="productname"/>
        <result property="productimage" column="productimage"/>
        <result property="producttype" column="producttype"/>
        <result property="productprice" column="productprice"/>
        <result property="stock" column="stock"/>
        <result property="productdesc" column="productdesc"/>
        <result property="addtime" column="addtime"/>
        <result property="favoritenum" column="favoritenum"/>
        <result property="likenum" column="likenum"/>
        <result property="stepnum" column="stepnum"/>
        <result property="clicknum" column="clicknum"/>
        <result property="clicktime" column="clicktime"/>
        <result property="auditstatus" column="auditstatus"/>
        <result property="auditreply" column="auditreply"/>
        <result property="discussnum" column="discussnum"/>
    </resultMap>

    <select id="selectListVO" resultType="com.entity.vo.ProductVO" >
        SELECT * FROM product product ${ew.customSqlSegment}
    </select>

    <select id="selectVO" resultType="com.entity.vo.ProductVO" >
        SELECT product.* FROM product product ${ew.customSqlSegment}
    </select>

    <select id="selectListView" resultType="com.entity.view.ProductView" >
        SELECT product.* FROM product product ${ew.customSqlSegment}
    </select>

    <select id="selectView" resultType="com.entity.view.ProductView" >
        SELECT * FROM product product ${ew.customSqlSegment}
    </select>


</mapper>
