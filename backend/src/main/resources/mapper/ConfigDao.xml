<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.ConfigDao">

    <resultMap type="com.entity.ConfigEntity" id="configMap">
        <result property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="value" column="value"/>
        <result property="url" column="url"/>
    </resultMap>

    <select id="selectListVO" resultType="com.entity.vo.ConfigVO" >
        SELECT * FROM config config ${ew.customSqlSegment}
    </select>

    <select id="selectVO" resultType="com.entity.vo.ConfigVO" >
        SELECT config.* FROM config config ${ew.customSqlSegment}
    </select>

    <select id="selectListView" resultType="com.entity.view.ConfigView" >
        SELECT config.* FROM config config ${ew.customSqlSegment}
    </select>

    <select id="selectView" resultType="com.entity.view.ConfigView" >
        SELECT * FROM config config ${ew.customSqlSegment}
    </select>


</mapper>
