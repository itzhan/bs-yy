<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.FriendDao">

    <resultMap type="com.entity.FriendEntity" id="friendMap">
        <result property="id" column="id"/>
        <result property="uid" column="uid"/>
        <result property="fid" column="fid"/>
        <result property="name" column="name"/>
        <result property="picture" column="picture"/>
        <result property="role" column="role"/>
        <result property="tablename" column="tablename"/>
        <result property="alias" column="alias"/>
        <result property="type" column="type"/>
        <result property="addtime" column="addtime"/>
        <result property="userid" column="userid"/>
    </resultMap>

    <select id="selectListVO" resultType="com.entity.vo.FriendVO" >
        SELECT * FROM friend friend ${ew.customSqlSegment}
    </select>

    <select id="selectVO" resultType="com.entity.vo.FriendVO" >
        SELECT friend.* FROM friend friend ${ew.customSqlSegment}
    </select>

    <select id="selectListView" resultType="com.entity.view.FriendView" >
        SELECT friend.* FROM friend friend ${ew.customSqlSegment}
    </select>

    <select id="selectView" resultType="com.entity.view.FriendView" >
        SELECT * FROM friend friend ${ew.customSqlSegment}
    </select>


</mapper>
