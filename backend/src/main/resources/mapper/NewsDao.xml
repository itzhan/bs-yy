<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.NewsDao">

    <resultMap type="com.entity.NewsEntity" id="newsMap">
        <result property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="introduction" column="introduction"/>
        <result property="typename" column="typename"/>
        <result property="name" column="name"/>
        <result property="avatar" column="avatar"/>
        <result property="image" column="image"/>
        <result property="content" column="content"/>
        <result property="addtime" column="addtime"/>
        <result property="favoritenum" column="favoritenum"/>
        <result property="likenum" column="likenum"/>
        <result property="stepnum" column="stepnum"/>
        <result property="clicknum" column="clicknum"/>
        <result property="clicktime" column="clicktime"/>
        <result property="auditstatus" column="auditstatus"/>
        <result property="auditreply" column="auditreply"/>
        <result property="discussnum" column="discussnum"/>
    </resultMap>

    <select id="selectListVO" resultType="com.entity.vo.NewsVO" >
        SELECT * FROM news news ${ew.customSqlSegment}
    </select>

    <select id="selectVO" resultType="com.entity.vo.NewsVO" >
        SELECT news.* FROM news news ${ew.customSqlSegment}
    </select>

    <select id="selectListView" resultType="com.entity.view.NewsView" >
        SELECT news.* FROM news news ${ew.customSqlSegment}
    </select>

    <select id="selectView" resultType="com.entity.view.NewsView" >
        SELECT * FROM news news ${ew.customSqlSegment}
    </select>


</mapper>
