<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.SocialDao">

    <resultMap type="com.entity.SocialEntity" id="socialMap">
        <result property="id" column="id"/>
        <result property="addtime" column="addtime"/>
        <result property="userid" column="userid"/>
        <result property="refid" column="refid"/>
        <result property="tablename" column="tablename"/>
        <result property="name" column="name"/>
        <result property="picture" column="picture"/>
        <result property="type" column="type"/>
        <result property="inteltype" column="inteltype"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <select id="selectListVO" resultType="com.entity.vo.SocialVO" >
        SELECT * FROM social social ${ew.customSqlSegment}
    </select>

    <select id="selectVO" resultType="com.entity.vo.SocialVO" >
        SELECT social.* FROM social social ${ew.customSqlSegment}
    </select>

    <select id="selectListView" resultType="com.entity.view.SocialView" >
        SELECT social.* FROM social social ${ew.customSqlSegment}
    </select>

    <select id="selectView" resultType="com.entity.view.SocialView" >
        SELECT * FROM social social ${ew.customSqlSegment}
    </select>

</mapper>