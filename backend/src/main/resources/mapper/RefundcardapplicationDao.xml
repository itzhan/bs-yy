    <select id="selectListVO" resultType="com.entity.vo.RefundcardapplicationVO" >
        SELECT * FROM refundcardapplication refundcardapplication ${ew.customSqlSegment}
    </select>

    <select id="selectVO" resultType="com.entity.vo.RefundcardapplicationVO" >
        SELECT refundcardapplication.* FROM refundcardapplication refundcardapplication ${ew.customSqlSegment}
    </select>

    <select id="selectListView" resultType="com.entity.view.RefundcardapplicationView" >
        SELECT refundcardapplication.* FROM refundcardapplication refundcardapplication ${ew.customSqlSegment}
    </select>

    <select id="selectView" resultType="com.entity.view.RefundcardapplicationView" >
        SELECT * FROM refundcardapplication refundcardapplication ${ew.customSqlSegment}
    </select>


</mapper>
