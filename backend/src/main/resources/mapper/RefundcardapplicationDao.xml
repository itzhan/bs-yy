<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.RefundcardapplicationDao">

    <resultMap type="com.entity.RefundcardapplicationEntity" id="refundcardapplicationMap">
        <result property="id" column="id"/>
        <result property="packagename" column="packagename"/>
        <result property="packageimage" column="packageimage"/>
        <result property="packagetype" column="packagetype"/>
        <result property="packageprice" column="packageprice"/>
        <result property="validdays" column="validdays"/>
        <result property="includedcourses" column="includedcourses"/>
        <result property="userid" column="userid"/>
        <result property="refundreason" column="refundreason"/>
        <result property="addtime" column="addtime"/>
        <result property="crossuserid" column="crossuserid"/>
        <result property="crossrefid" column="crossrefid"/>
