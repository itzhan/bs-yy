<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.TrainingrecordDao">

    <resultMap type="com.entity.TrainingrecordEntity" id="trainingrecordMap">
        <result property="id" column="id"/>
        <result property="planid" column="planid"/>
        <result property="planname" column="planname"/>
        <result property="userid" column="userid"/>
        <result property="useraccount" column="useraccount"/>
        <result property="username" column="username"/>
        <result property="coachid" column="coachid"/>
        <result property="coachaccount" column="coachaccount"/>
        <result property="coachname" column="coachname"/>
        <result property="recorddate" column="recorddate"/>
        <result property="duration" column="duration"/>
        <result property="completionrate" column="completionrate"/>
        <result property="content" column="content"/>
        <result property="coachcomment" column="coachcomment"/>
        <result property="addtime" column="addtime"/>
    </resultMap>

    <select id="selectListVO" resultType="com.entity.vo.TrainingrecordVO" >
        SELECT * FROM trainingrecord trainingrecord ${ew.customSqlSegment}
    </select>

    <select id="selectVO" resultType="com.entity.vo.TrainingrecordVO" >
        SELECT trainingrecord.* FROM trainingrecord trainingrecord ${ew.customSqlSegment}
    </select>

    <select id="selectListView" resultType="com.entity.view.TrainingrecordView" >
        SELECT trainingrecord.* FROM trainingrecord trainingrecord ${ew.customSqlSegment}
    </select>

    <select id="selectView" resultType="com.entity.view.TrainingrecordView" >
        SELECT * FROM trainingrecord trainingrecord ${ew.customSqlSegment}
    </select>

</mapper>
