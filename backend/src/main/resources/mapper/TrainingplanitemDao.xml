<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.TrainingplanitemDao">

    <resultMap type="com.entity.TrainingplanitemEntity" id="trainingplanitemMap">
        <result property="id" column="id"/>
        <result property="planid" column="planid"/>
        <result property="planname" column="planname"/>
        <result property="userid" column="userid"/>
        <result property="coachid" column="coachid"/>
        <result property="dayno" column="dayno"/>
        <result property="itemcontent" column="itemcontent"/>
        <result property="target" column="target"/>
        <result property="sortno" column="sortno"/>
        <result property="remark" column="remark"/>
        <result property="addtime" column="addtime"/>
    </resultMap>

    <select id="selectListVO" resultType="com.entity.vo.TrainingplanitemVO" >
        SELECT * FROM trainingplanitem trainingplanitem ${ew.customSqlSegment}
    </select>

    <select id="selectVO" resultType="com.entity.vo.TrainingplanitemVO" >
        SELECT trainingplanitem.* FROM trainingplanitem trainingplanitem ${ew.customSqlSegment}
    </select>

    <select id="selectListView" resultType="com.entity.view.TrainingplanitemView" >
        SELECT trainingplanitem.* FROM trainingplanitem trainingplanitem ${ew.customSqlSegment}
    </select>

    <select id="selectView" resultType="com.entity.view.TrainingplanitemView" >
        SELECT * FROM trainingplanitem trainingplanitem ${ew.customSqlSegment}
    </select>

</mapper>
