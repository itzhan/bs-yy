<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.ChatDao">

    <resultMap type="com.entity.ChatEntity" id="chatMap">
        <result property="id" column="id"/>
        <result property="userid" column="userid"/>
        <result property="adminid" column="adminid"/>
        <result property="ask" column="ask"/>
        <result property="reply" column="reply"/>
        <result property="asktype" column="asktype"/>
        <result property="replytype" column="replytype"/>
        <result property="isreply" column="isreply"/>
        <result property="isread" column="isread"/>
        <result property="uname" column="uname"/>
        <result property="uimage" column="uimage"/>
        <result property="addtime" column="addtime"/>
    </resultMap>

    <select id="selectListVO" resultType="com.entity.vo.ChatVO" >
        SELECT * FROM chat chat ${ew.customSqlSegment}
    </select>

    <select id="selectVO" resultType="com.entity.vo.ChatVO" >
        SELECT chat.* FROM chat chat ${ew.customSqlSegment}
    </select>

    <select id="selectListView" resultType="com.entity.view.ChatView" >
        SELECT chat.* FROM chat chat ${ew.customSqlSegment}
    </select>

    <select id="selectView" resultType="com.entity.view.ChatView" >
        SELECT * FROM chat chat ${ew.customSqlSegment}
    </select>


</mapper>
