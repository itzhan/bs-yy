<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.DiscussproductDao">

    <resultMap type="com.entity.DiscussproductEntity" id="discussproductMap">
        <result property="id" column="id"/>
        <result property="refid" column="refid"/>
        <result property="userid" column="userid"/>
        <result property="nickname" column="nickname"/>
        <result property="avatarurl" column="avatarurl"/>
        <result property="content" column="content"/>
        <result property="reply" column="reply"/>
        <result property="likenum" column="likenum"/>
        <result property="stepnum" column="stepnum"/>
        <result property="addtime" column="addtime"/>
    </resultMap>

    <select id="selectListVO" resultType="com.entity.vo.DiscussproductVO" >
        SELECT * FROM discussproduct discussproduct ${ew.customSqlSegment}
    </select>

    <select id="selectVO" resultType="com.entity.vo.DiscussproductVO" >
        SELECT discussproduct.* FROM discussproduct discussproduct ${ew.customSqlSegment}
    </select>

    <select id="selectListView" resultType="com.entity.view.DiscussproductView" >
        SELECT discussproduct.* FROM discussproduct discussproduct ${ew.customSqlSegment}
    </select>

    <select id="selectView" resultType="com.entity.view.DiscussproductView" >
        SELECT * FROM discussproduct discussproduct ${ew.customSqlSegment}
    </select>


</mapper>
