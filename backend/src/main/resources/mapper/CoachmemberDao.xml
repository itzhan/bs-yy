<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.CoachmemberDao">

    <resultMap type="com.entity.CoachmemberEntity" id="coachmemberMap">
        <result property="id" column="id"/>
        <result property="coachid" column="coachid"/>
        <result property="coachaccount" column="coachaccount"/>
        <result property="coachname" column="coachname"/>
        <result property="userid" column="userid"/>
        <result property="useraccount" column="useraccount"/>
        <result property="username" column="username"/>
        <result property="phone" column="phone"/>
        <result property="userimage" column="userimage"/>
        <result property="bindstatus" column="bindstatus"/>
        <result property="remark" column="remark"/>
        <result property="addtime" column="addtime"/>
    </resultMap>

    <select id="selectListVO" resultType="com.entity.vo.CoachmemberVO" >
        SELECT * FROM coachmember coachmember ${ew.customSqlSegment}
    </select>

    <select id="selectVO" resultType="com.entity.vo.CoachmemberVO" >
        SELECT coachmember.* FROM coachmember coachmember ${ew.customSqlSegment}
    </select>

    <select id="selectListView" resultType="com.entity.view.CoachmemberView" >
        SELECT coachmember.* FROM coachmember coachmember ${ew.customSqlSegment}
    </select>

    <select id="selectView" resultType="com.entity.view.CoachmemberView" >
        SELECT * FROM coachmember coachmember ${ew.customSqlSegment}
    </select>

</mapper>
