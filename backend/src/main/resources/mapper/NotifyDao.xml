<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.NotifyDao">

    <resultMap type="com.entity.NotifyEntity" id="notifyMap">
        <result property="id" column="id"/>
        <result property="userid" column="userid"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="messagetype" column="messagetype"/>
        <result property="readstatus" column="readstatus"/>
        <result property="senduser" column="senduser"/>
        <result property="addtime" column="addtime"/>
    </resultMap>

    <select id="selectListVO" resultType="com.entity.vo.NotifyVO" >
        SELECT * FROM notify notify ${ew.customSqlSegment}
    </select>

    <select id="selectVO" resultType="com.entity.vo.NotifyVO" >
        SELECT notify.* FROM notify notify ${ew.customSqlSegment}
    </select>

    <select id="selectListView" resultType="com.entity.view.NotifyView" >
        SELECT notify.* FROM notify notify ${ew.customSqlSegment}
    </select>

    <select id="selectView" resultType="com.entity.view.NotifyView" >
        SELECT * FROM notify notify ${ew.customSqlSegment}
    </select>


</mapper>
