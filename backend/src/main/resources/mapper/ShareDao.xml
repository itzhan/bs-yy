<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.ShareDao">

    <resultMap type="com.entity.ShareEntity" id="shareMap">
        <result property="id" column="id"/>
        <result property="sharetitle" column="sharetitle"/>
        <result property="sharecontent" column="sharecontent"/>
        <result property="shareimage" column="shareimage"/>
        <result property="sharetype" column="sharetype"/>
        <result property="addtime" column="addtime"/>
        <result property="favoritenum" column="favoritenum"/>
        <result property="likenum" column="likenum"/>
        <result property="stepnum" column="stepnum"/>
        <result property="clicknum" column="clicknum"/>
        <result property="clicktime" column="clicktime"/>
        <result property="auditstatus" column="auditstatus"/>
        <result property="auditreply" column="auditreply"/>
        <result property="discussnum" column="discussnum"/>
    </resultMap>

    <select id="selectListVO" resultType="com.entity.vo.ShareVO" >
        SELECT * FROM share share ${ew.customSqlSegment}
    </select>

    <select id="selectVO" resultType="com.entity.vo.ShareVO" >
        SELECT share.* FROM share share ${ew.customSqlSegment}
    </select>

    <select id="selectListView" resultType="com.entity.view.ShareView" >
        SELECT share.* FROM share share ${ew.customSqlSegment}
    </select>

    <select id="selectView" resultType="com.entity.view.ShareView" >
        SELECT * FROM share share ${ew.customSqlSegment}
    </select>


</mapper>
