<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.FeedbackDao">

    <resultMap type="com.entity.FeedbackEntity" id="feedbackMap">
        <result property="id" column="id"/>
        <result property="feedbacktitle" column="feedbacktitle"/>
        <result property="feedbackcontent" column="feedbackcontent"/>
        <result property="feedbacktype" column="feedbacktype"/>
        <result property="userid" column="userid"/>
        <result property="addtime" column="addtime"/>
        <result property="auditstatus" column="auditstatus"/>
        <result property="auditreply" column="auditreply"/>
    </resultMap>

    <select id="selectListVO" resultType="com.entity.vo.FeedbackVO" >
        SELECT * FROM feedback feedback ${ew.customSqlSegment}
    </select>

    <select id="selectVO" resultType="com.entity.vo.FeedbackVO" >
        SELECT feedback.* FROM feedback feedback ${ew.customSqlSegment}
    </select>

    <select id="selectListView" resultType="com.entity.view.FeedbackView" >
        SELECT feedback.* FROM feedback feedback ${ew.customSqlSegment}
    </select>

    <select id="selectView" resultType="com.entity.view.FeedbackView" >
        SELECT * FROM feedback feedback ${ew.customSqlSegment}
    </select>


</mapper>
